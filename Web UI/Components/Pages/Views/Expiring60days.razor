@page "/views/expiring60days"

@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using CertificateManager.Models
@using CertificateManager.Models.Views
@using CertificateManager.Data
@using Microsoft.AspNetCore.Components.QuickGrid
@using CertificateManager.Services
@implements IAsyncDisposable
@inject CertificateService certificateService

<PageTitle>List certificates that will expire in the next 60 days</PageTitle>

<h3>List certificates that will expire in the next 60 days</h3>

<QuickGrid Class="table" Items="entry" Pagination="_pagination">
    <Paginator State="_pagination" />
    <PropertyColumn Property="@(e => e.RequestId)" Title="Request" Sortable="true" />
    <TemplateColumn Title="RequesterInformation">
        @if (context.RequestCommonName != "")
        {
            <p style="display:inline">CN=@context.RequestCommonName<br /></p>
        }
        @if (context.RequestCountryRegion != "")
        {
            <p style="display:inline">C=@context.RequestCountryRegion<br /></p>
        }
        @if (context.RequestCity != "")
        {
            <p style="display:inline">L=@context.RequestCity<br /></p>
        }
        @if (context.RequestOrganization != "")
        {
            <p style="display:inline">O=@context.RequestOrganization<br /></p>
        }
        @if (context.RequestOrganizationUnit != "")
        {
            <p style="display:inline">OU=@context.RequestOrganizationUnit<br /></p>
        }
        @if (context.RequestEMailAddress != "")
        {
            <p style="display:inline">E=@context.RequestEMailAddress<br /></p>
        }
    </TemplateColumn>
    <TemplateColumn Title=SubjectAlternativeNames>
        @if (context.SubjectAlternativeNames != "")
        {
            foreach (var san in @context.SubjectAlternativeNames.Split(","))
            {
                <p style="display:inline">@san<br /></p>
            }
        }
    </TemplateColumn>
    <TemplateColumn Title=EnhancedKeyUsages>
        @if (context.EKUNames != "")
        {
            foreach (var eku in @context.EKUNames.Split(","))
            {
                <p style="display:inline">@eku<br /></p>
            }
        }
    </TemplateColumn>
    <PropertyColumn Property="@(e => e.Owner)" Sortable="true" />
    <PropertyColumn Property="@(e => e.Notes)" Sortable="true" />
    <TemplateColumn Context="Entry">
        <a href="@($"certificates/edit?requestid={Entry.RequestId}&caconfig={Entry.CAConfig}")">Edit</a> |
        <a href="@($"certificates/revoke?serialnumber={Entry.SerialNumber}")">Revoke</a>
    </TemplateColumn>

</QuickGrid>

@code {
    public enum DispositionOptions
    {
        Under_Review = 9,
        Certificate_Issued = 20,
        Certificate_Revoked = 21,
        Request_Failed = 30,
        Request_Denied = 31
    }
    public DispositionOptions DispositionOption { get; set; } = DispositionOptions.Certificate_Issued;

    public int? requestId = null;
    public DateTime? expirationDate = null;

    private System.Collections.Hashtable _filterht = new System.Collections.Hashtable();

    private AppDbContext _context = default!;
    private PaginationState _pagination = new PaginationState { ItemsPerPage = 10 };

    protected override void OnInitialized()
    {
        _context = certificateService.CreateDbContext();
        _filterht["RequestDisposition"] = (int)DispositionOption;
        expirationDate = DateTime.Today.AddDays(60);
    }

    private IQueryable<ExtendedEntry> entry => certificateService.GetCertificateEntries(_context, requestId, expirationDate, _filterht);

    public async ValueTask DisposeAsync() => await _context.DisposeAsync();
}

