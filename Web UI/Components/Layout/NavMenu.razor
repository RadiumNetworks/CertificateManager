<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CertificateManager</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="certificates/list" Match="NavLinkMatch.All">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> List Certificate entries
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="requests/list" Match="NavLinkMatch.All">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> List Certificate requests
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="requests/new" Match="NavLinkMatch.All">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> New certificate requests
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="certificates/import" Match="NavLinkMatch.All">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Import external Certificates
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" @onclick="() => _expandSubNav = !_expandSubNav" Match="NavLinkMatch.All">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Default views
            </NavLink>
            @if (_expandSubNav)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="views/expiring30days">
                        <span class="bi bi-plus-square-fill-nav-menu"></span> 30 days to expire
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="views/expiring60days">
                        <span class="bi bi-plus-square-fill-nav-menu"></span> 60 days to expire
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="views/wildcard">
                        <span class="bi bi-plus-square-fill-nav-menu"></span> Wildcard certificates
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="views/codesigning">
                        <span class="bi bi-plus-square-fill-nav-menu"></span> Codesigning certificates
                    </NavLink>
                </div>
            }
        </div>
    </nav>
</div>

@code {
    private bool _expandSubNav = false;

}