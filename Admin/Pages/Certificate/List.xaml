<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Certificate_Manager.Pages.Certificate.List"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Certificate_Manager.Pages.Certificate"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Database Entries"
            Style="{StaticResource TitleTextBlockStyle}"
            Grid.Row="0" />

        <!-- Input fields + Submit -->
        <StackPanel Orientation="Horizontal" Spacing="16" Grid.Row="1">
            <TextBox x:Name="SubjectInput"
              Header="Subject"
              PlaceholderText="Enter subject filter..."
              Width="180" />

            <TextBox x:Name="OwnerInput"
              Header="Owner"
              PlaceholderText="Enter owner filter..."
              Width="180" />

            <TextBox x:Name="TemplateInput"
              Header="Template"
              PlaceholderText="Enter template filter..."
              Width="200" />

            <NumberBox x:Name="RequestIdInput"
              Header="RequestId"
              PlaceholderText="Enter request id..."
              Width="180" />
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" Spacing="16" Grid.Row="2">
            <TextBox x:Name="CAInput"
                Header="CA"
                PlaceholderText="Choose certificate authority..."
                Width="200" />

            <TextBox x:Name="DispositionCodeInput"
                Header="DispositionCode"
                PlaceholderText="Choose disposition status..."
                Width="200" />

            <DatePicker x:Name="DateInput"
                Header="Choose maximum expiration date" />
            
        </StackPanel>
        <Button x:Name="SearchButton"
                Grid.Row="3"
                 Content="Search"
                 Click="SearchButton_Click"
                 VerticalAlignment="Bottom"
                 Style="{StaticResource AccentButtonStyle}"
                 Padding="24,8" />

        <!-- Sortable DataGrid -->
        <controls:DataGrid
            x:Name="EntryDataGrid"
            Grid.Row="4"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            CanUserReorderColumns="True"
            CanUserResizeColumns="True"
            IsReadOnly="True"
            GridLinesVisibility="Horizontal"
            AlternatingRowBackground="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">

            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="RequestId"
                                              Binding="{Binding RequestId}"
                                              Tag="RequestId"
                                              Width="90" />
                <controls:DataGridTextColumn Header="RequesterInformation"
                                              Binding="{Binding RequesterInformation}"
                                              Tag="RequesterInformation"
                                              Width="250" />
                <controls:DataGridTextColumn Header="SubjectAlternativeName"
                                              Binding="{Binding SubjectAlternativeNamesFormatted}"
                                              Tag="SubjectAlternativeNames"
                                              Width="320" />
                <controls:DataGridTextColumn Header="EnhancedKeyUsage"
                                              Binding="{Binding EKUNamesFormatted}"
                                              Tag="EnhancedKeyUsage"
                                              Width="180" />
                <controls:DataGridTextColumn Header="Owner"
                                              Binding="{Binding Owner}"
                                              Tag="Owner"
                                              Width="140" />
                <controls:DataGridTextColumn Header="Notes"
                                              Binding="{Binding Notes}"
                                              Tag="Notes"
                                              Width="140" />
            </controls:DataGrid.Columns>
        </controls:DataGrid>
    </Grid>

</Page>
